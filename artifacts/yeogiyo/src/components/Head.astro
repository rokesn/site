---
import type { City } from '../i18n/cities';

interface Props {
  city?: City | null;
  isRoot?: boolean;
  metaTitle?: string;
  metaDescription?: string;
}

const { city = null, isRoot = false, metaTitle, metaDescription } = Astro.props;

const DOMAIN = '여기여.site';
const BRAND = '여기여';
const PUBLISHER = '여기여';
const PUBLISHER_URL = 'https://www.ygy01.com/';
const GITHUB_URL = 'https://github.com/%EC%97%AC%EA%B8%B0%EC%97%AC';
const GSC_TOKEN = 'YOUR_GSC_TOKEN';
const BING_TOKEN = 'YOUR_BING_TOKEN';
const CLARITY_ID = '';

const slug = city?.slug ?? '';
const selfPath = slug ? `/${slug}/` : '/';
const selfUrl = `https://${DOMAIN}${selfPath}`;

const pageTitle = metaTitle ?? (city ? city.metaTitle : `여기여 - 최신 주소 바로가기 | 지역별 링크 허브`);
const pageDesc = metaDescription ?? (city ? city.metaDescription : `여기여 최신 주소를 한 곳에서 바로 확인하세요. 전국 18개 지역 여기여 주소(yugiyu)를 매일 검증해 제공합니다.`);
const pageKeywords = city
  ? `여기여, ${city.name} 여기여, 여기여 주소, yugiyu, 여기여 최신주소, ${city.name} 맛집, ${city.name} 정보, ${city.districts.join(', ')} 여기여`
  : `여기여, 여기여 주소, yugiyu, 여기여 최신주소, 여기여 사이트, 여기여 링크, 여기여 접속, 여기여 바로가기`;

const today = new Date().toISOString().slice(0, 10);

const breadcrumbItems: object[] = [
  { '@type': 'ListItem', position: 1, name: '여기여 홈', item: `https://${DOMAIN}/` },
];
if (city) {
  breadcrumbItems.push({
    '@type': 'ListItem',
    position: 2,
    name: `${city.name} 여기여`,
    item: selfUrl,
  });
}

const jsonLdGraph: object[] = [
  ...(isRoot || !city ? [{
    '@type': 'Organization',
    '@id': `https://${DOMAIN}/#organization`,
    name: PUBLISHER,
    url: PUBLISHER_URL,
    logo: { '@type': 'ImageObject', url: `https://${DOMAIN}/apple-touch-icon.png` },
    sameAs: [GITHUB_URL, PUBLISHER_URL],
  }] : []),
  {
    '@type': 'WebSite',
    '@id': `https://${DOMAIN}/#website`,
    url: `https://${DOMAIN}/`,
    name: BRAND,
    inLanguage: 'ko-KR',
    publisher: { '@id': `https://${DOMAIN}/#organization` },
    potentialAction: {
      '@type': 'SearchAction',
      target: { '@type': 'EntryPoint', urlTemplate: `https://${DOMAIN}/?q={search_term_string}` },
      'query-input': 'required name=search_term_string',
    },
  },
  {
    '@type': 'WebPage',
    '@id': selfUrl + '#webpage',
    url: selfUrl,
    name: pageTitle,
    inLanguage: 'ko-KR',
    isPartOf: { '@id': `https://${DOMAIN}/#website` },
    dateModified: today,
    ...(city ? {
      about: {
        '@type': 'Place',
        name: city.name,
        address: {
          '@type': 'PostalAddress',
          addressCountry: 'KR',
          addressRegion: city.name,
        },
        geo: {
          '@type': 'GeoCoordinates',
          latitude: city.lat,
          longitude: city.lng,
        },
      },
    } : {}),
  },
  {
    '@type': 'BreadcrumbList',
    '@id': selfUrl + '#breadcrumb',
    itemListElement: breadcrumbItems,
  },
  {
    '@type': 'FAQPage',
    '@id': selfUrl + '#faqpage',
    mainEntity: [
      { '@type': 'Question', name: '여기여(yugiyu)는 무엇인가요?', acceptedAnswer: { '@type': 'Answer', text: '여기여(yugiyu 또는 yeogiyo)는 웹 주소를 집계하고 검증하는 한국의 인기 인터넷 링크 허브입니다. 빠르고, 무료이며, 탐색이 쉽습니다.' } },
      { '@type': 'Question', name: '여기여 주소는 왜 변경되나요?', acceptedAnswer: { '@type': 'Answer', text: '여기여는 서비스 가용성 유지를 위해 주기적으로 도메인을 업데이트합니다. 이 페이지는 항상 현재 검증된 여기여 주소를 표시합니다.' } },
      { '@type': 'Question', name: '여기여는 무료인가요?', acceptedAnswer: { '@type': 'Answer', text: '네, 여기여는 완전 무료입니다. 이 링크 허브도 무료입니다.' } },
      ...(city ? [
        { '@type': 'Question', name: `${city.name} 여기여는 어떻게 접속하나요?`, acceptedAnswer: { '@type': 'Answer', text: `${city.name} 여기여 최신 주소는 이 페이지(여기여.site/${city.slug}/)를 북마크하고 필요할 때마다 방문하세요.` } },
      ] : []),
    ],
  },
];

const jsonLd = { '@context': 'https://schema.org', '@graph': jsonLdGraph };
---

<meta charset="UTF-8" />
<link rel="icon" href="/favicon.ico" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<meta name="apple-mobile-web-app-title" content={BRAND} />
<link rel="manifest" href="/site.webmanifest" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="msvalidate.01" content={BING_TOKEN} />
<meta name="google-site-verification" content={GSC_TOKEN} />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+KR:wght@400;500;700&display=swap" />
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+KR:wght@400;500;700&display=swap" media="print" onload="this.media='all'" />
<noscript>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+KR:wght@400;500;700&display=swap" />
</noscript>

<title>{pageTitle}</title>
<meta name="description" content={pageDesc} />
<meta name="keywords" content={pageKeywords} />
<meta name="author" content={PUBLISHER} />
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
<link rel="canonical" href={selfUrl} />

<!-- Geo meta tags (city pages) -->
{city && (
  <>
    <meta name="geo.region" content={city.iso} />
    <meta name="geo.placename" content={city.name} />
    <meta name="geo.position" content={`${city.lat};${city.lng}`} />
    <meta name="ICBM" content={`${city.lat}, ${city.lng}`} />
  </>
)}

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content={BRAND} />
<meta property="og:url" content={selfUrl} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={pageDesc} />
<meta property="og:image" content={`https://${DOMAIN}/og/og-ko.png`} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={city ? `${city.name} 여기여 — 공식 링크 허브` : '여기여 — 공식 링크 허브'} />
<meta property="og:locale" content="ko_KR" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={selfUrl} />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={pageDesc} />
<meta name="twitter:image" content={`https://${DOMAIN}/og/og-ko.png`} />

<!-- JSON-LD -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

{CLARITY_ID && (
  <script is:inline define:vars={{ clarityId: CLARITY_ID }}>
    setTimeout(function(){
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;
        t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];
        y.parentNode.insertBefore(t,y);
      })(window,document,"clarity","script",clarityId);
    }, 1500);
  </script>
)}
