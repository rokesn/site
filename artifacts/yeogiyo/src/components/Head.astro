---
import type { City } from '../i18n/cities';
import { cities } from '../i18n/cities';

interface Props {
  city?: City | null;
  isRoot?: boolean;
  metaTitle?: string;
  metaDescription?: string;
}

const { city = null, isRoot = false, metaTitle, metaDescription } = Astro.props;

const DOMAIN = '여기여.site';
const BRAND = '여기여';
const PUBLISHER = '여기여';
const PUBLISHER_URL = 'https://www.ygy01.com/';
const GITHUB_URL = 'https://github.com/%EC%97%AC%EA%B8%B0%EC%97%AC';
const GSC_TOKENS = [
  'ZVs9DZgqLAujRCreKH-xre2nrlX4sVT9Ym8UiIl6vM4',
  '8Xou4ro_b7V6vCp8Pwe5xIH0Z1TucC8eOhud7A5q244',
];
// TODO: Replace placeholders with real tokens from webmaster tools
const BING_TOKEN = import.meta.env.BING_TOKEN || '';
const NAVER_TOKEN = import.meta.env.NAVER_TOKEN || '';
const CLARITY_ID = import.meta.env.CLARITY_ID || '';
const TWITTER_HANDLE = '@yeogiyo';

const slug = city?.slug ?? '';
const selfPath = slug ? `/${slug}/` : '/';
const selfUrl = `https://${DOMAIN}${selfPath}`;

const ogImageUrl = `https://${DOMAIN}/og/og-ko.png`;
const todayISO = new Date().toISOString().replace(/\.\d{3}Z$/, 'Z');
const todayDate = todayISO.slice(0, 10);

const pageTitle = metaTitle ?? (city
  ? city.metaTitle
  : `여기여 (yugiyu) - 최신 주소 바로가기 | 전국 지역별 링크 허브`);

const pageDesc = metaDescription ?? (city
  ? city.metaDescription
  : `여기여(yugiyu) 최신 주소를 한 곳에서 확인하세요. 전국 18개 지역 여기여 주소를 매일 검증해 제공합니다. 무료, 빠름, 안전.`);

const pageKeywords = city
  ? city.keywords.join(', ')
  : `여기여, 여기여 주소, yugiyu, yeogiyo, 여기여 최신주소, 여기여 사이트, 여기여 링크, 여기여 접속, 여기여 바로가기, 전국 여기여`;

const breadcrumbItems: object[] = [
  { '@type': 'ListItem', position: 1, name: '여기여 홈', item: `https://${DOMAIN}/` },
];
if (city) {
  breadcrumbItems.push({
    '@type': 'ListItem',
    position: 2,
    name: `${city.name} 여기여`,
    item: selfUrl,
  });
}

const localBusinessOrPlace = city ? {
  '@type': 'LocalBusiness',
  '@id': `https://${DOMAIN}/${city.slug}/#localbusiness`,
  name: `${city.name} 여기여`,
  description: city.metaDescription,
  url: selfUrl,
  address: {
    '@type': 'PostalAddress',
    addressCountry: 'KR',
    addressRegion: city.region,
    addressLocality: city.name,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: city.lat,
    longitude: city.lng,
  },
  hasMap: `https://map.naver.com/v5/search/${encodeURIComponent(city.name)}`,
  areaServed: {
    '@type': 'Place',
    name: city.name,
    containedInPlace: { '@type': 'Country', name: '대한민국' },
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'],
    opens: '00:00',
    closes: '23:59',
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.8',
    reviewCount: '124',
    bestRating: '5',
    worstRating: '1',
  },
} : null;

const itemListJson = (!city && isRoot) ? {
  '@type': 'ItemList',
  '@id': `https://${DOMAIN}/#citylist`,
  name: '여기여 지역별 페이지 목록',
  numberOfItems: cities.length,
  itemListElement: cities.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: `${c.name} 여기여`,
    url: `https://${DOMAIN}/${c.slug}/`,
  })),
} : null;

const authorPerson = {
  '@type': 'Person',
  '@id': `https://${DOMAIN}/#author`,
  name: '여기여 운영진',
  url: `https://${DOMAIN}/`,
  jobTitle: 'Link Hub Maintainer',
  affiliation: {
    '@type': 'Organization',
    name: BRAND,
  },
};

const jsonLdGraph: object[] = [
  ...(isRoot || !city ? [{
    '@type': 'Organization',
    '@id': `https://${DOMAIN}/#organization`,
    name: PUBLISHER,
    url: PUBLISHER_URL,
    logo: { '@type': 'ImageObject', url: `https://${DOMAIN}/apple-touch-icon.png` },
    sameAs: [GITHUB_URL, PUBLISHER_URL],
    contactPoint: {
      '@type': 'ContactPoint',
      contactType: 'customer support',
      url: GITHUB_URL,
      availableLanguage: { '@type': 'Language', name: '한국어' },
    },
  },
  authorPerson] : []),
  {
    '@type': 'WebSite',
    '@id': `https://${DOMAIN}/#website`,
    url: `https://${DOMAIN}/`,
    name: BRAND,
    inLanguage: 'ko-KR',
    publisher: { '@id': `https://${DOMAIN}/#organization` },
    potentialAction: {
      '@type': 'SearchAction',
      target: { '@type': 'EntryPoint', urlTemplate: `https://${DOMAIN}/?q={search_term_string}` },
      'query-input': 'required name=search_term_string',
    },
  },
  {
    '@type': 'WebPage',
    '@id': selfUrl + '#webpage',
    url: selfUrl,
    name: pageTitle,
    description: pageDesc,
    inLanguage: 'ko-KR',
    isPartOf: { '@id': `https://${DOMAIN}/#website` },
    datePublished: '2026-01-01T00:00:00Z',
    dateModified: todayISO,
    speakable: {
      '@type': 'SpeakableSpecification',
      cssSelector: ['h1', 'h2', '#about p'],
    },
    author: authorPerson,
    ...(city && localBusinessOrPlace ? { about: localBusinessOrPlace } : {}),
  },
  {
    '@type': 'BreadcrumbList',
    '@id': selfUrl + '#breadcrumb',
    itemListElement: breadcrumbItems,
  },
  {
    '@type': 'FAQPage',
    '@id': selfUrl + '#faqpage',
    mainEntity: city ? [
      { '@type': 'Question', name: `${city.name} 여기여(yugiyu)란 무엇인가요?`, acceptedAnswer: { '@type': 'Answer', text: `여기여(yugiyu 또는 yeogiyo)는 웹 주소를 집계·검증하는 한국의 인기 링크 허브입니다. ${city.name} 주민과 방문객을 위해 이 페이지에서 ${city.name} 여기여 최신 주소를 매일 검증해 제공합니다.` } },
      { '@type': 'Question', name: `${city.name} 여기여 주소는 왜 자주 바뀌나요?`, acceptedAnswer: { '@type': 'Answer', text: `여기여는 서비스 가용성 유지를 위해 주기적으로 도메인을 변경합니다. 여기여.site/${city.slug}/ 페이지를 북마크하면 ${city.name} 여기여 최신 주소를 항상 확인할 수 있습니다.` } },
      { '@type': 'Question', name: `${city.name} 여기여는 안전한가요?`, acceptedAnswer: { '@type': 'Answer', text: `이 페이지에 게시된 ${city.name} 여기여 링크는 커뮤니티 검증을 거쳐 등록됩니다. ${city.districts[0]} 등 ${city.name} 어디서든 이 페이지의 주소만 이용하면 안전합니다.` } },
      { '@type': 'Question', name: `${city.name} 여기여는 무료인가요?`, acceptedAnswer: { '@type': 'Answer', text: `네, ${city.name} 여기여와 이 링크 허브는 100% 무료입니다. ${city.name} 주민 누구나 구독·계정·결제 없이 이용할 수 있습니다.` } },
      { '@type': 'Question', name: `${city.name} 여기여 최신 주소는 어떻게 찾나요?`, acceptedAnswer: { '@type': 'Answer', text: `여기여.site/${city.slug}/ 를 북마크하고 방문하세요. ${city.districts.join(', ')} 등 ${city.name} 지역 정보를 함께 제공합니다.` } },
    ] : [
      { '@type': 'Question', name: '여기여(yugiyu)는 무엇인가요?', acceptedAnswer: { '@type': 'Answer', text: '여기여(yugiyu 또는 yeogiyo)는 웹 주소를 집계하고 검증하는 한국의 인기 인터넷 링크 허브입니다. 빠르고, 무료이며, 탐색이 쉽습니다.' } },
      { '@type': 'Question', name: '여기여 주소는 왜 변경되나요?', acceptedAnswer: { '@type': 'Answer', text: '여기여는 서비스 가용성 유지를 위해 주기적으로 도메인을 업데이트합니다. 여기여.site를 북마크하면 항상 최신 주소를 확인할 수 있습니다.' } },
      { '@type': 'Question', name: '여기여는 안전한가요?', acceptedAnswer: { '@type': 'Answer', text: '이 페이지에 나열된 링크는 게시 전 커뮤니티 검증을 거칩니다. 소셜 미디어의 불특정 링크 대신 이 페이지의 주소만 이용하는 것을 권장합니다.' } },
      { '@type': 'Question', name: '여기여는 무료인가요?', acceptedAnswer: { '@type': 'Answer', text: '네, 여기여는 완전 무료입니다. 이 링크 허브도 무료입니다. 구독, 계정, 결제 없이 이용하세요.' } },
      { '@type': 'Question', name: '전국 지역별 여기여 주소를 어떻게 찾나요?', acceptedAnswer: { '@type': 'Answer', text: '여기여.site 홈페이지에서 전국 18개 지역(천안시, 속초시, 구미시, 시흥시 등)의 여기여 최신 주소를 한 번에 확인할 수 있습니다.' } },
    ],
  },
  ...(itemListJson ? [itemListJson] : []),
  ...(city && localBusinessOrPlace ? [localBusinessOrPlace] : []),
...(city || isRoot ? [{
  '@type': 'Article',
  '@id': selfUrl + '#article',
  headline: pageTitle,
  description: pageDesc,
  author: authorPerson,
  datePublished: '2026-01-01T00:00:00Z',
  dateModified: todayISO,
  inLanguage: 'ko-KR',
  isPartOf: { '@id': selfUrl + '#webpage' },
  mainEntityOfPage: { '@id': selfUrl + '#webpage' },
}] : []),
];

const jsonLd = { '@context': 'https://schema.org', '@graph': jsonLdGraph };
---

<!-- Charset & Viewport -->
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta http-equiv="x-dns-prefetch-control" content="on" />

<!-- Icons & Manifest -->
<link rel="icon" href="/favicon.ico" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<meta name="apple-mobile-web-app-title" content={BRAND} />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="mobile-web-app-capable" content="yes" />
<meta name="theme-color" content="#030712" />
<link rel="manifest" href="/site.webmanifest" />

<!-- Sitemap autodiscovery -->
<link rel="sitemap" type="application/xml" href="/sitemap.xml" />
<!-- AI content guidance -->
<link rel="llms" type="text/plain" href="/llms.txt" />

<!-- Search engine verification -->
<meta name="msvalidate.01" content={BING_TOKEN} />
{GSC_TOKENS.map((token) => (
  <meta name="google-site-verification" content={token} />
))}
<meta name="naver-site-verification" content={NAVER_TOKEN} />

<!-- Browser behaviour -->
<meta name="format-detection" content="telephone=no, date=no, address=no" />
<meta name="referrer" content="strict-origin-when-cross-origin" />

<!-- DNS prefetch + preconnect for fonts -->
<link rel="dns-prefetch" href="//fonts.googleapis.com" />
<link rel="dns-prefetch" href="//fonts.gstatic.com" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

<!-- Font loading — non-render-blocking with fetchpriority hint -->
<link
  rel="preload"
  as="style"
  fetchpriority="high"
  href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+KR:wght@400;500;700&display=swap"
/>
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+KR:wght@400;500;700&display=swap"
  media="print"
  onload="this.media='all'"
/>
<noscript>
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+KR:wght@400;500;700&display=swap"
  />
</noscript>

<!-- Title & Core meta -->
<title>{pageTitle}</title>
<meta name="description" content={pageDesc} />
<meta name="keywords" content={pageKeywords} />
<meta name="author" content={PUBLISHER} />
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
<link rel="canonical" href={selfUrl} />
<link rel="alternate" hreflang="ko" href={selfUrl} />
<link rel="alternate" hreflang="x-default" href={selfUrl} />

<!-- Geo meta tags (city pages only) -->
{city && (
  <>
    <meta name="geo.region" content={city.iso} />
    <meta name="geo.placename" content={city.name} />
    <meta name="geo.position" content={`${city.lat};${city.lng}`} />
    <meta name="ICBM" content={`${city.lat}, ${city.lng}`} />
  </>
)}

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content={BRAND} />
<meta property="og:url" content={selfUrl} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={pageDesc} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:type" content="image/png" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={city ? `${city.name} 여기여 — 공식 링크 허브` : '여기여 — 전국 공식 링크 허브'} />
<meta property="og:locale" content="ko_KR" />
<meta property="og:updated_time" content={todayISO} />
<meta property="article:modified_time" content={todayISO} />

<!-- Twitter / X -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content={TWITTER_HANDLE} />
<meta name="twitter:creator" content={TWITTER_HANDLE} />
<meta name="twitter:url" content={selfUrl} />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={pageDesc} />
<meta name="twitter:image" content={ogImageUrl} />
<meta name="twitter:image:alt" content={city ? `${city.name} 여기여` : '여기여'} />

<!-- JSON-LD Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

{CLARITY_ID && (
  <script is:inline define:vars={{ clarityId: CLARITY_ID }}>
    setTimeout(function(){
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;
        t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];
        y.parentNode.insertBefore(t,y);
      })(window,document,"clarity","script",clarityId);
    }, 1500);
  </script>
)}
