---
import { cities } from '../i18n/cities';
import type { City } from '../i18n/cities';

interface Props {
  city?: City | null;
}

const { city = null } = Astro.props;
const year = new Date().getFullYear();
const currentPath = city ? `/${city.slug}/` : '/';
---

<footer class="bg-gray-900 border-t border-gray-800 mt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div>
        <a href="/" class="text-2xl font-bold text-white hover:text-blue-400 transition-colors">
          여기여
        </a>
        <p class="mt-3 text-sm text-gray-400 max-w-xs">
          공식 여기여 링크 허브 — 항상 최신, 항상 검증됨.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h3 class="text-sm font-semibold text-gray-300 uppercase tracking-wider mb-4">링크</h3>
        <ul class="space-y-2">
          <li>
            <a href="https://www.ygy01.com/" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-400 hover:text-white transition-colors">
              여기여 공식 사이트
            </a>
          </li>
          <li>
            <a href="https://github.com/%EC%97%AC%EA%B8%B0%EC%97%AC" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-400 hover:text-white transition-colors">
              GitHub
            </a>
          </li>
          <li>
            <a href={`${currentPath}privacy/`} class="text-sm text-gray-400 hover:text-white transition-colors">개인정보처리방침</a>
          </li>
          <li>
            <a href={`${currentPath}terms/`} class="text-sm text-gray-400 hover:text-white transition-colors">이용약관</a>
          </li>
        </ul>
      </div>

      <!-- Info -->
      <div>
        <h3 class="text-sm font-semibold text-gray-300 uppercase tracking-wider mb-4">정보</h3>
        <p class="text-sm text-gray-400">무료 이용</p>
        <p class="text-sm text-gray-400 mt-2">
          문의: <a href="https://github.com/%EC%97%AC%EA%B8%B0%EC%97%AC" target="_blank" rel="noopener noreferrer" class="text-blue-400 hover:text-blue-300 transition-colors">GitHub</a>
        </p>
        <p class="text-sm text-gray-400 mt-2">
          운영자: 여기여 운영진
        </p>
        <p class="text-sm text-gray-400 mt-2">
          최종 업데이트: 2026-06-21
        </p>
        <p class="text-sm text-gray-500 mt-2">© {year} 여기여. 모든 권리 보유.</p>
      </div>

      <!-- Korea Regions -->
      <div>
        <h3 class="text-sm font-semibold text-gray-300 uppercase tracking-wider mb-4">한국 지역 (Korea Regions)</h3>
        <ul class="grid grid-cols-2 gap-x-4 gap-y-1.5">
          <li>
            <a href="/" class="text-sm text-gray-400 hover:text-white transition-colors">전국</a>
          </li>
          {cities.map((c) => (
            <li>
              <a href={`/${c.slug}/`} class="text-sm text-gray-400 hover:text-white transition-colors">
                {c.name}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</footer>
