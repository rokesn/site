---
import type { Locale } from '../i18n';
import { localePaths } from '../i18n';

interface Props {
  locale: string;
  t: Locale;
}

const { locale, t } = Astro.props;
const currentPath = localePaths[locale] ?? '/';
const year = new Date().getFullYear();
---

<footer class="bg-gray-900 border-t border-gray-800 mt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <a href={currentPath} class="text-2xl font-bold text-white hover:text-blue-400 transition-colors">
          여기여
        </a>
        <p class="mt-3 text-sm text-gray-400 max-w-xs">
          {t.footer.tagline}
        </p>
      </div>

      <!-- Links -->
      <div>
        <h3 class="text-sm font-semibold text-gray-300 uppercase tracking-wider mb-4">Links</h3>
        <ul class="space-y-2">
          <li>
            <a
              href="https://www.ygy01.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-gray-400 hover:text-white transition-colors"
            >
              여기여 공식 사이트
            </a>
          </li>
          <li>
            <a
              href="https://github.com/%EC%97%AC%EA%B8%B0%EC%97%AC"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-gray-400 hover:text-white transition-colors"
            >
              GitHub
            </a>
          </li>
          <li>
            <a href={`${currentPath}privacy/`} class="text-sm text-gray-400 hover:text-white transition-colors">
              {t.footer.privacy}
            </a>
          </li>
          <li>
            <a href={`${currentPath}terms/`} class="text-sm text-gray-400 hover:text-white transition-colors">
              {t.footer.terms}
            </a>
          </li>
        </ul>
      </div>

      <!-- Info -->
      <div>
        <h3 class="text-sm font-semibold text-gray-300 uppercase tracking-wider mb-4">Info</h3>
        <p class="text-sm text-gray-400">{t.footer.license}</p>
        <p class="text-sm text-gray-500 mt-1">© {year} 여기여. {t.footer.rights}</p>
      </div>
    </div>
  </div>
</footer>
