---
import type { Locale } from '../i18n';
import { localePaths, localeNames } from '../i18n';

interface Props {
  locale: string;
  t: Locale;
}

const { locale, t } = Astro.props;
const currentPath = localePaths[locale] ?? '/';
---

<header class="sticky top-0 z-50 bg-gray-950/90 backdrop-blur-md border-b border-gray-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href={currentPath} class="flex items-center gap-2 group">
        <span class="text-2xl font-bold text-white group-hover:text-blue-400 transition-colors">
          여기여
        </span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-6" aria-label="Main navigation">
        <a href="#features" class="text-sm text-gray-400 hover:text-white transition-colors">
          {t.nav.features}
        </a>
        <a href="#about" class="text-sm text-gray-400 hover:text-white transition-colors">
          {t.nav.useCases}
        </a>
        <a href="#quickstart" class="text-sm text-gray-400 hover:text-white transition-colors">
          {t.nav.quickStart}
        </a>
        <a href="#faq" class="text-sm text-gray-400 hover:text-white transition-colors">
          {t.nav.faq}
        </a>
        <a
          href="https://github.com/%EC%97%AC%EA%B8%B0%EC%97%AC"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-gray-400 hover:text-white transition-colors"
        >
          {t.nav.github}
        </a>
      </nav>

      <!-- Language Switcher -->
      <div class="flex items-center">
        <label for="lang-select" class="sr-only">Select language</label>
        <select
          id="lang-select"
          class="bg-gray-800 text-gray-300 text-sm rounded-lg px-3 py-1.5 border border-gray-700 hover:border-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500 cursor-pointer"
          aria-label="Select language"
        >
          {Object.entries(localePaths).map(([l, path]) => (
            <option value={path} selected={l === locale}>
              {localeNames[l]}
            </option>
          ))}
        </select>
      </div>
    </div>
  </div>
</header>
