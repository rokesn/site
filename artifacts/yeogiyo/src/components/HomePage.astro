---
import type { City } from '../i18n/cities';
import { cities, getRelatedCities } from '../i18n/cities';
import FeatureCard from './FeatureCard.astro';
import FaqAccordion from './FaqAccordion.astro';

interface Props {
  city?: City | null;
}

const { city = null } = Astro.props;

const cityName = city?.name ?? '';
const districts = city?.districts ?? [];
const relatedCities = city ? getRelatedCities(city.slug) : [];

const h1 = city
  ? `${cityName} 여기여 - ${city.h1Secondary}`
  : '여기여 (yugiyu) — 전국 최신 주소 링크 허브';

const h2Features = city
  ? `${cityName} 여기여를 이용해야 하는 이유`
  : '왜 여기여.site가 가장 신뢰받는 링크 허브인가';

const features = city
  ? [
      { icon: '⚡', title: `${cityName} 여기여 주소 매일 업데이트`, description: `${cityName} 공식 여기여 주소는 매일 검증 후 업데이트됩니다. ${cityName} 주민과 방문객 모두 항상 작동하는 최신 링크를 이용할 수 있습니다.` },
      { icon: '🔗', title: `${cityName} 여기여 즉시 접속`, description: `${cityName} 여기여는 회원가입 없이 클릭 즉시 접속됩니다. ${districts[0] ?? cityName} 등 ${cityName} 어디서든 빠르게 로딩됩니다.` },
      { icon: '✅', title: '커뮤니티 검증 링크', description: `${cityName} 여기여 링크는 등록 전 커뮤니티 검증을 거칩니다. 가짜 사이트나 피싱 페이지에 절대 연결되지 않습니다.` },
      { icon: '📱', title: `${cityName} 모바일 최적화`, description: `스마트폰에서 ${cityName} 여기여 주소를 즉시 확인하세요. 이동 중에도 빠르게 접속할 수 있도록 최적화되어 있습니다.` },
      { icon: '🔒', title: '안전하고 보안적인 접속', description: `${cityName} 여기여 모든 주소는 보안 검사를 통과했습니다. 이 페이지를 북마크하면 ${cityName}에서 언제나 안전하게 접속할 수 있습니다.` },
      { icon: '🆓', title: '완전 무료 서비스', description: `${cityName} 여기여 링크 허브는 100% 무료입니다. ${cityName} 주민 누구나 구독·결제 없이 자유롭게 이용하세요.` },
    ]
  : [
      { icon: '⚡', title: '매일 업데이트되는 여기여 주소', description: '공식 여기여 주소는 매일 검증 후 업데이트됩니다. 항상 작동하는 최신 링크를 제공합니다.' },
      { icon: '🔗', title: '즉시 접속, 복잡함 없음', description: '회원가입 불필요. 링크 클릭 즉시 여기여에 도착합니다. 어떤 기기나 네트워크에서도 빠르게 로딩됩니다.' },
      { icon: '✅', title: '커뮤니티 검증 링크', description: '모든 여기여 링크는 등록 전 커뮤니티 검증을 거칩니다. 가짜 사이트나 피싱 페이지에 절대 연결되지 않습니다.' },
      { icon: '📱', title: '모바일 최적화', description: '스마트폰과 태블릿에 완벽하게 최적화되어 있어 이동 중에도 여기여 주소를 쉽게 찾을 수 있습니다.' },
      { icon: '🔒', title: '안전하고 보안적인 접속', description: '모든 주소는 보안 검사를 통과했습니다. 이 페이지를 북마크하면 검색 엔진 없이도 안전하게 접속할 수 있습니다.' },
      { icon: '🆓', title: '완전 무료', description: '여기여와 이 링크 허브는 100% 무료입니다. 구독, 숨겨진 요금, 광고 없이 자유롭게 이용하세요.' },
    ];

const faqs = city
  ? [
      { question: `${cityName} 여기여(yugiyu)란 무엇인가요?`, answer: `여기여(yugiyu 또는 yeogiyo)는 웹 주소를 집계·검증하는 한국의 인기 링크 허브입니다. ${cityName} 주민과 방문객을 위해 이 페이지에서 ${cityName} 여기여 최신 주소를 매일 검증해 제공합니다.` },
      { question: `${cityName} 여기여 주소는 왜 자주 바뀌나요?`, answer: `여기여는 서비스 가용성 유지를 위해 주기적으로 도메인을 변경합니다. 이 페이지(여기여.site/${city.slug}/)를 북마크하면 ${cityName} 여기여 최신 주소를 항상 확인할 수 있습니다.` },
      { question: `${cityName} 여기여는 안전한가요?`, answer: `이 페이지에 게시된 ${cityName} 여기여 링크는 커뮤니티 검증을 거쳐 등록됩니다. 소셜 미디어의 불특정 링크 대신 이 페이지 주소만 이용하시면 안전합니다.` },
      { question: `${cityName} 여기여 최신 주소는 어떻게 찾나요?`, answer: `여기여.site/${city.slug}/ 페이지를 북마크하고 주소가 필요할 때 방문하세요. ${districts.join(', ')} 등 ${cityName} 지역 정보도 함께 제공됩니다.` },
      { question: `${cityName} 여기여에 접속이 안 될 때는?`, answer: `${cityName} 여기여 주소가 변경된 경우 이 페이지로 돌아오면 최신 검증 주소를 바로 확인할 수 있습니다. 이 페이지를 즐겨찾기에 추가해 두는 것을 권장합니다.` },
      { question: "'여기여'는 한국어로 무슨 뜻인가요?", answer: "'여기여(yeogiyo)'는 '바로 여기!'라는 뜻의 한국어 표현입니다. 필요한 모든 정보가 바로 여기에 있다는 뜻입니다." },
      { question: `${cityName} 여기여는 무료인가요?`, answer: `네, ${cityName} 여기여와 이 링크 허브는 100% 무료입니다. ${cityName} 주민 누구나 구독·계정·결제 없이 이용할 수 있습니다.` },
    ]
  : [
      { question: '여기여(yugiyu)는 무엇인가요?', answer: '여기여(yugiyu 또는 yeogiyo)는 웹 주소를 집계하고 검증하는 한국의 인기 인터넷 링크 허브입니다. 빠르고, 무료이며, 탐색이 쉽습니다.' },
      { question: '여기여 주소는 왜 변경되나요?', answer: '여기여는 서비스 가용성 유지를 위해 주기적으로 도메인을 업데이트합니다. 이 페이지는 항상 현재 검증된 여기여 주소를 표시합니다.' },
      { question: '여기여는 안전한가요?', answer: '이 페이지에 나열된 링크는 게시 전 커뮤니티 검증을 거칩니다. 무작위 소셜 미디어 게시물의 링크가 아닌 이 페이지의 주소만 이용하는 것을 권장합니다.' },
      { question: '최신 여기여 주소는 어떻게 찾나요?', answer: '여기여.site를 북마크하고 주소가 필요할 때마다 방문하세요. 도메인 변경 후 몇 시간 내에 링크를 업데이트합니다.' },
      { question: "'여기여'는 한국어로 무슨 뜻인가요?", answer: "'여기여(yeogiyo)'는 '바로 여기!'라는 뜻의 한국어 표현입니다. 플랫폼의 미션을 반영합니다: 필요한 모든 것이 바로 여기에." },
      { question: '여기여, yugiyu, yeogiyo의 차이점은 무엇인가요?', answer: '차이 없습니다 — yugiyu와 yeogiyo는 같은 한국어 단어 여기여의 로마자 표기 방식이 다를 뿐입니다. 세 가지 표기 모두 검색에 커버됩니다.' },
      { question: '여기여는 무료인가요?', answer: '네, 여기여는 완전 무료입니다. 이 링크 허브도 무료입니다. 최신 여기여 주소를 찾고 접속하는 데 구독, 계정, 결제가 일절 필요하지 않습니다.' },
    ];

const quickStartSteps = [
  {
    title: '1단계 — 이 페이지 북마크 저장',
    description: `Ctrl+D(Mac은 Cmd+D)를 눌러 여기여.site${city ? `/${city.slug}/` : ''}를 북마크하세요.`,
    code: `# 북마크할 URL:\nhttps://여기여.site${city ? `/${city.slug}/` : ''}`,
  },
  {
    title: '2단계 — 최신 여기여 주소 확인',
    description: '이 페이지의 링크 섹션으로 스크롤해 현재 검증된 여기여 주소를 확인하세요.',
    code: '# 최신 검증된 여기여 주소:\nhttps://www.ygy01.com/',
  },
  {
    title: '3단계 — 접속 및 이용',
    description: '링크를 클릭해 여기여로 바로 이동하세요. 임시 중단 시에는 미러 섹션에서 대체 주소를 확인하세요.',
    code: '# 대체 미러 링크 목록:\nhttps://여기여.site',
  },
];
---

<!-- Breadcrumb (city pages) — visible + microdata for Yeti/Google -->
{city && (
  <nav aria-label="breadcrumb" class="bg-gray-900 border-b border-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2.5">
      <ol class="flex items-center gap-2 text-sm text-gray-400" itemscope itemtype="https://schema.org/BreadcrumbList">
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a itemprop="item" href="/" class="hover:text-white transition-colors">
            <span itemprop="name">여기여 홈</span>
          </a>
          <meta itemprop="position" content="1" />
        </li>
        <li aria-hidden="true" class="text-gray-600">/</li>
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span itemprop="name" class="text-gray-200">{cityName} 여기여</span>
          <meta itemprop="item" content={`https://여기여.site/${city.slug}/`} />
          <meta itemprop="position" content="2" />
        </li>
      </ol>
    </div>
  </nav>
)}

<!-- Hero -->
<section id="hero" class="relative overflow-hidden bg-gray-950 pt-20 pb-24">
  <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:64px_64px]" aria-hidden="true"></div>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-blue-600/10 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="inline-flex items-center gap-2 bg-blue-600/10 border border-blue-600/20 rounded-full px-4 py-1.5 text-xs text-blue-400 mb-6">
      <span class="w-1.5 h-1.5 rounded-full bg-blue-400 animate-pulse"></span>
      Daily verified · 매일 검증
      {city && <span class="ml-1 text-blue-300">· {city.name}</span>}
    </div>

    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white tracking-tight mb-6 leading-tight">
      {h1}
    </h1>

    {city ? (
      <p class="text-xl sm:text-2xl text-gray-300 font-light mb-4 max-w-2xl mx-auto leading-relaxed">
        {city.uniqueIntro}
      </p>
    ) : (
      <p class="text-xl sm:text-2xl text-gray-300 font-light mb-4 max-w-2xl mx-auto leading-relaxed">
        여기여 최신 주소를 매일 검증해 한 곳에 모아드립니다. 더 이상 주소를 검색할 필요가 없어요.
      </p>
    )}

    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="https://www.ygy01.com/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-500 text-white font-semibold px-8 py-3.5 rounded-xl transition-colors duration-200 text-base"
      >
        여기여 바로가기
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
        </svg>
      </a>
      <a
        href="#quickstart"
        class="inline-flex items-center gap-2 bg-gray-800 hover:bg-gray-700 text-white font-semibold px-8 py-3.5 rounded-xl transition-colors duration-200 text-base border border-gray-700"
      >
        이용 방법 보기
      </a>
    </div>

    <!-- Latest address badge -->
    <div class="mt-12 inline-flex items-center gap-3 bg-gray-900 border border-gray-800 rounded-xl px-6 py-3">
      <span class="w-2 h-2 rounded-full bg-green-400 flex-shrink-0"></span>
      <span class="text-sm text-gray-400">최신 여기여 주소:</span>
      <a href="https://www.ygy01.com/" target="_blank" rel="noopener noreferrer" class="text-sm font-mono text-blue-400 hover:text-blue-300 transition-colors">
        www.ygy01.com
      </a>
    </div>
  </div>
</section>

<!-- Features -->
<section id="features" class="py-20 bg-gray-950">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-white text-center mb-4">{h2Features}</h2>
    <p class="text-gray-400 text-center mb-12 max-w-2xl mx-auto">여기여 주소를 쉽고 빠르게 찾는 방법</p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {features.map((f) => (
        <FeatureCard title={f.title} description={f.description} icon={f.icon} />
      ))}
    </div>
  </div>
</section>

<!-- Local Highlights (city pages only) — 100% unique per city -->
{city && city.localHighlights.length > 0 && (
  <section id="highlights" class="py-16 bg-gray-900/70">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white text-center mb-3">
        {cityName} 여기여가 필요한 순간
      </h2>
      <p class="text-gray-400 text-center text-sm mb-10">
        {cityName} 지역 주민과 방문객을 위한 여기여 접속 안내
      </p>
      <ul class="space-y-4">
        {city.localHighlights.map((highlight) => (
          <li class="flex items-start gap-4 bg-gray-900 border border-gray-800 rounded-xl p-5">
            <span class="flex-shrink-0 w-6 h-6 rounded-full bg-blue-600/20 border border-blue-600/40 flex items-center justify-center mt-0.5" aria-hidden="true">
              <svg class="w-3 h-3 text-blue-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
            </span>
            <p class="text-gray-200 text-sm leading-relaxed">{highlight}</p>
          </li>
        ))}
      </ul>
      <div class="mt-8 text-center">
        <a
          href="https://www.ygy01.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-500 text-white font-semibold px-6 py-3 rounded-xl transition-colors text-sm"
        >
          {cityName} 여기여 바로가기 ↗
        </a>
      </div>
    </div>
  </section>
)}

<!-- City Districts (city pages only) -->
{city && districts.length > 0 && (
  <section id="districts" class="py-20 bg-gray-900/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white text-center mb-4">{cityName} 지역별 여기여 안내</h2>
      <p class="text-gray-400 text-center mb-12 max-w-2xl mx-auto">{cityName} {city.region} 주요 읍·면·동별 여기여 주소 및 지역 정보</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        {districts.map((district) => (
          <article class="bg-gray-900 border border-gray-800 rounded-xl p-6 hover:border-blue-800 transition-colors text-center">
            <h3 class="text-base font-semibold text-white mb-2">{district} 여기여 주소</h3>
            <p class="text-sm text-gray-400">{cityName} {district} 지역 최신 여기여(yugiyu) 주소와 접속 정보를 제공합니다</p>
          </article>
        ))}
      </div>
    </div>
  </section>
)}

<!-- City Hub Index (root page only) -->
{!city && (
  <section id="regions" class="py-20 bg-gray-900/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white text-center mb-4">지역별 여기여 바로가기</h2>
      <p class="text-gray-400 text-center mb-12 max-w-2xl mx-auto">전국 18개 주요 도시 · 군의 여기여 최신 주소를 확인하세요</p>
      <nav aria-label="지역별 여기여 링크">
        <ul class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3">
          {cities.map((c) => (
            <li>
              <a
                href={`/${c.slug}/`}
                class="flex flex-col items-center justify-center bg-gray-900 border border-gray-800 rounded-xl p-4 hover:border-blue-700 hover:bg-gray-900/80 transition-all duration-200 text-center group"
              >
                <span class="text-sm font-semibold text-white group-hover:text-blue-400 transition-colors leading-snug">{c.name}</span>
                <span class="text-xs text-gray-500 mt-1">여기여</span>
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </section>
)}

<!-- About -->
<section id="about" class="py-20 bg-gray-950">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-white mb-8 text-center">
      {city ? `${cityName} 여기여란?` : '여기여(yugiyu)란 무엇인가?'}
    </h2>
    <div class="space-y-6">
      <p class="text-gray-300 leading-relaxed text-base">
