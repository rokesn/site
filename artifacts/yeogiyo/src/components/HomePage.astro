<!-- Quick Start -->
<section id="quickstart" class="py-20 bg-gray-900/50">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-white text-center mb-12">여기여 3단계 접속 방법</h2>
    <ol class="space-y-6">
      {quickStartSteps.map((step, i) => (
        <li class="bg-gray-900 border border-gray-800 rounded-xl p-6 hover:border-blue-800 transition-colors">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-blue-600 text-white font-bold text-lg flex items-center justify-center">{i + 1}</div>
            <div class="flex-1">
              <h3 class="text-base font-semibold text-white mb-2">{step.title}</h3>
              <p class="text-sm text-gray-400 mb-4 leading-relaxed">{step.description}</p>
              <pre class="bg-gray-950 rounded-lg p-4 text-sm text-green-400 font-mono overflow-x-auto border border-gray-800 whitespace-pre-wrap"><code>{step.code}</code></pre>
            </div>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<!-- FAQ -->
<section id="faq" class="py-20 bg-gray-950">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-white text-center mb-12">
      {city ? `${cityName} 여기여 자주 묻는 질문` : '여기여에 관해 자주 묻는 질문'}
    </h2>
    <FaqAccordion faqs={faqs} />
  </div>
</section>

<!-- Related Cities (city pages only) — internal linking -->
{city && relatedCities.length > 0 && (
  <section id="related" class="py-16 bg-gray-900/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white text-center mb-3">
        {city.region} 다른 지역 여기여
      </h2>
      <p class="text-gray-400 text-center mb-10 text-sm">같은 지역의 여기여 최신 주소도 확인해보세요</p>
      <nav aria-label="관련 지역 여기여">
        <ul class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {relatedCities.map((rc) => (
            <li>
              <a
                href={`/${rc.slug}/`}
                class="flex flex-col items-center justify-center bg-gray-900 border border-gray-800 rounded-xl p-5 hover:border-blue-700 transition-all group text-center"
              >
                <span class="text-sm font-semibold text-white group-hover:text-blue-400 transition-colors">{rc.name}</span>
                <span class="text-xs text-gray-500 mt-1">여기여 바로가기 →</span>
              </a>
            </li>
          ))}
        </ul>
      </nav>
      <p class="text-center mt-8">
        <a href="/" class="text-sm text-gray-400 hover:text-white transition-colors underline underline-offset-2">
          ← 전국 모든 지역 여기여 보기
        </a>
      </p>
    </div>
  </section>
)}

