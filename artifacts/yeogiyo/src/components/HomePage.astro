---
import type { Locale } from '../i18n';
import FeatureCard from './FeatureCard.astro';
import FaqAccordion from './FaqAccordion.astro';

interface Props {
  locale: string;
  t: Locale;
}

const { locale, t } = Astro.props;

const featureIcons = ['⚡', '🔗', '✅', '📱', '🔒', '🆓'];
const capabilityIcons = ['🔖', '🪞', '📡', '📂', '🌐', '💬'];
const stepIcons = ['1', '2', '3'];
---

<!-- Hero -->
<section id="hero" class="relative overflow-hidden bg-gray-950 pt-20 pb-24">
  <!-- Grid background -->
  <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:64px_64px]" aria-hidden="true"></div>
  <!-- Glow -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-blue-600/10 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="inline-flex items-center gap-2 bg-blue-600/10 border border-blue-600/20 rounded-full px-4 py-1.5 text-xs text-blue-400 mb-6">
      <span class="w-1.5 h-1.5 rounded-full bg-blue-400 animate-pulse"></span>
      Daily verified · 매일 검증
    </div>

    <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-white tracking-tight mb-6">
      여기여
    </h1>

    <p class="text-xl sm:text-2xl text-gray-300 font-light mb-4 max-w-2xl mx-auto leading-relaxed">
      {t.hero.tagline}
    </p>

    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="https://www.ygy01.com/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-500 text-white font-semibold px-8 py-3.5 rounded-xl transition-colors duration-200 text-base"
        data-testid="cta-primary"
      >
        {t.hero.ctaPrimary}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
        </svg>
      </a>
      <a
        href="#quickstart"
        class="inline-flex items-center gap-2 bg-gray-800 hover:bg-gray-700 text-white font-semibold px-8 py-3.5 rounded-xl transition-colors duration-200 text-base border border-gray-700"
        data-testid="cta-secondary"
      >
        {t.hero.ctaSecondary}
      </a>
    </div>

    <!-- Latest address badge -->
    <div class="mt-12 inline-flex items-center gap-3 bg-gray-900 border border-gray-800 rounded-xl px-6 py-3">
      <span class="w-2 h-2 rounded-full bg-green-400 flex-shrink-0"></span>
      <span class="text-sm text-gray-400">최신 여기여 주소:</span>
      <a
        href="https://www.ygy01.com/"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm font-mono text-blue-400 hover:text-blue-300 transition-colors"
      >
        www.ygy01.com
      </a>
    </div>
  </div>
</section>

<!-- Features -->
<section id="features" class="py-20 bg-gray-950">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-white text-center mb-4">{t.featuresHeading}</h2>
    <p class="text-gray-400 text-center mb-12 max-w-2xl mx-auto">여기여 주소를 쉽고 빠르게 찾는 방법</p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {t.features.map((feature, i) => (
        <FeatureCard
          title={feature.title}
          description={feature.description}
          icon={featureIcons[i]}
        />
      ))}
    </div>
  </div>
</section>

<!-- Capabilities -->
<section id="capabilities" class="py-20 bg-gray-900/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-white text-center mb-4">{t.capabilitiesHeading}</h2>
    <p class="text-gray-400 text-center mb-12 max-w-2xl mx-auto">yugiyu 사용을 더욱 편리하게</p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {t.capabilities.map((cap, i) => (
        <FeatureCard
          title={cap.title}
          description={cap.description}
          icon={capabilityIcons[i]}
        />
      ))}
    </div>
  </div>
</section>

<!-- About -->
<section id="about" class="py-20 bg-gray-950">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-white mb-8 text-center">{t.whatIsHeading}</h2>
    <div class="prose prose-invert prose-lg max-w-none">
      {t.whatIsBody.split('\n\n').map((para) => (
        <p class="text-gray-300 leading-relaxed mb-6 text-base">{para}</p>
      ))}
    </div>
  </div>
</section>

<!-- Use Cases -->
<section id="training" class="py-20 bg-gray-900/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-white text-center mb-12">{t.useCasesHeading}</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {t.useCases.map((uc) => (
        <article class="bg-gray-900 border border-gray-800 rounded-xl p-6 hover:border-blue-800 transition-colors">
          <h3 class="text-base font-semibold text-white mb-3 flex items-start gap-2">
            <span class="w-5 h-5 rounded-md bg-blue-600/20 text-blue-400 flex items-center justify-center text-xs flex-shrink-0 mt-0.5">→</span>
            {uc.title}
          </h3>
          <p class="text-sm text-gray-400 leading-relaxed">{uc.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- Quick Start -->
<section id="quickstart" class="py-20 bg-gray-950">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-white text-center mb-12">{t.quickStartHeading}</h2>
    <ol class="space-y-6">
      {t.quickStartSteps.map((step, i) => (
        <li class="bg-gray-900 border border-gray-800 rounded-xl p-6 hover:border-blue-800 transition-colors">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-blue-600 text-white font-bold text-lg flex items-center justify-center">
              {i + 1}
            </div>
            <div class="flex-1">
              <h3 class="text-base font-semibold text-white mb-2">{step.title}</h3>
              <p class="text-sm text-gray-400 mb-4 leading-relaxed">{step.description}</p>
              <pre class="bg-gray-950 rounded-lg p-4 text-sm text-green-400 font-mono overflow-x-auto border border-gray-800 whitespace-pre-wrap"><code>{step.code}</code></pre>
            </div>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<!-- FAQ -->
<section id="faq" class="py-20 bg-gray-900/50">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-white text-center mb-12">{t.faqHeading}</h2>
    <FaqAccordion faqs={t.faqs} />
  </div>
</section>

<!-- Final CTA -->
<section id="cta-final" class="py-24 bg-gray-950 relative overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_rgba(37,99,235,0.1)_0%,_transparent_70%)]" aria-hidden="true"></div>
  <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-4xl font-bold text-white mb-6">{t.finalCtaHeading}</h2>
    <p class="text-gray-400 mb-10 text-lg">여기여.site — Always the latest 여기여 주소</p>
    <a
      href="https://www.ygy01.com/"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-500 text-white font-semibold px-10 py-4 rounded-xl transition-colors duration-200 text-lg"
      data-testid="cta-final"
    >
      {t.finalCtaButton}
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
      </svg>
    </a>
  </div>
</section>
