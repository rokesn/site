---
interface Props {
  title: string;
  description: string;
  icon?: string;
}

const { title, description, icon = '✦' } = Astro.props;
---

<article class="bg-gray-900 border border-gray-800 rounded-xl p-6 hover:border-blue-800 hover:bg-gray-800/50 transition-all duration-200 group">
  <div class="flex items-start gap-4">
    <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-blue-600/10 border border-blue-600/20 flex items-center justify-center text-blue-400 text-lg group-hover:bg-blue-600/20 transition-colors">
      {icon}
    </div>
    <div>
      <h3 class="text-base font-semibold text-white mb-2">{title}</h3>
      <p class="text-sm text-gray-400 leading-relaxed">{description}</p>
    </div>
  </div>
</article>
